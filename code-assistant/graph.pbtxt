# OVMS mediapipe graph for OpenAI-compatible LLM serving.
#
# Generated by `ovms --pull --task text_generation` against
# OpenVINO/Qwen3-Coder-30B-A3B-Instruct-int4-ov on OVMS 2026.1.
# Hand-edited: tool_parser corrected from "qwen3" to "qwen3coder"
# (the OVMS pull tool defaults to "qwen3" for any Qwen3 model, but the
# Coder variant uses a different XML format and needs the dedicated
# Qwen3CoderToolParser).
#
# To regenerate from scratch:
#   ovms --pull --task text_generation \
#     --source_model OpenVINO/Qwen3-Coder-30B-A3B-Instruct-int4-ov \
#     --model_repository_path /models \
#     --model_name qwen3-coder \
#     --target_device GPU \
#     --tool_parser qwen3coder \
#     --kv_cache_precision u8

input_stream: "HTTP_REQUEST_PAYLOAD:input"
output_stream: "HTTP_RESPONSE_PAYLOAD:output"
node: {
  name: "LLMExecutor"
  calculator: "HttpLLMCalculator"
  input_stream: "LOOPBACK:loopback"
  input_stream: "HTTP_REQUEST_PAYLOAD:input"
  input_side_packet: "LLM_NODE_RESOURCES:llm"
  output_stream: "LOOPBACK:loopback"
  output_stream: "HTTP_RESPONSE_PAYLOAD:output"
  input_stream_info: {
    tag_index: 'LOOPBACK:0',
    back_edge: true
  }
  node_options: {
    [type.googleapis.com / mediapipe.LLMCalculatorOptions]: {
      max_num_seqs: 256,
      device: "GPU",
      models_path: "./",
      plugin_config: '{"KV_CACHE_PRECISION":"u8"}',
      enable_prefix_caching: true,
      cache_size: 0,
      tool_parser: "qwen3coder",
    }
  }
  input_stream_handler {
    input_stream_handler: "SyncSetInputStreamHandler",
    options {
      [mediapipe.SyncSetInputStreamHandlerOptions.ext] {
        sync_set {
          tag_index: "LOOPBACK:0"
        }
      }
    }
  }
}
